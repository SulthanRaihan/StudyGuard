rules_version = '2';

// StudyGuard Firestore security rules.
// Each user may only read/write their own data. Collections that store a
// `userId` field are scoped by that field; user-keyed collections by document id.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Existing doc belongs to the caller.
    function ownsResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Incoming (created/updated) doc is stamped with the caller's uid.
    function ownsIncoming() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // users/{userId}
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Collections carrying a userId field on each document.
    match /sessions/{sessionId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncoming();
    }
    match /postureEvents/{eventId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncoming();
    }
    match /focusEvents/{eventId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncoming();
    }
    match /focusSamples/{sampleId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncoming();
    }
    match /breakSessions/{breakId} {
      allow read, update, delete: if ownsResource();
      allow create: if ownsIncoming();
    }

    // achievements/{userId}/{badgeId}
    match /achievements/{userId}/{badgeId} {
      allow read, write: if isOwner(userId);
    }
  }
}
