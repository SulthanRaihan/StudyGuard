<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>GoogleSignIn</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1032663200252-0eop4808ta84pt0k49p4qo54dovhjknn</string>
			</array>
		</dict>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Lets the app call the local CrewAI dev backend (e.g. http://192.168.x.x:8000)
		     over plain HTTP. Scoped to local-network/IP-literal hosts only -- does NOT
		     weaken ATS for any public/internet host (Firebase, Groq, ExerciseDB all
		     still require HTTPS as normal). -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
